{
  "project": {
    "name": "octobercms",
    "repo": "https://github.com/octobercms/october",
    "root_path": "/home/eric/.openclaw/share-cep-agent/octobercms/project"
  },
  "environment": {
    "requires_docker": true,
    "ports": [8080]
  },
  "artifacts": {
    "project_path": "/home/eric/.openclaw/share-cep-agent/octobercms/project",
    "image": "octobercms-app:v1",
    "container": "octobercms-app"
  },
  "official_step_mapping": [],
  "steps": [
    {
      "id": "step_fix_mirror",
      "action": "fix_mirror_links",
      "working_dir": "/home/eric/.openclaw/share-cep-agent/octobercms",
      "command": "docker-compose exec app bash -c 'if [ ! -f /var/www/html/index.php ]; then echo \"Creating index.php...\" && cat > /var/www/html/index.php << \"EOF\"\n<?php\n/**\n * October CMS index file\n */\nrequire __DIR__ . \"/../bootstrap/autoload.php\";\n\\$app = require_once __DIR__ . \"/../bootstrap/app.php\";\n\\$kernel = \\$app->make(Illuminate\\\\Contracts\\\\Http\\\\Kernel::class);\n\\$response = \\$kernel->handle(\\$request = Illuminate\\\\Http\\\\Request::capture());\n\\$response->send();\n\\$kernel->terminate(\\$request, \\$response);\nEOF\nfi'",
      "creates": [],
      "depends_on": []
    },
    {
      "id": "step_fix_public_index",
      "action": "create_public_index",
      "working_dir": "/home/eric/.openclaw/share-cep-agent/octobercms",
      "command": "if [ -L /home/eric/.openclaw/share-cep-agent/octobercms/project/public/index.php ]; then rm /home/eric/.openclaw/share-cep-agent/octobercms/project/public/index.php && cp /home/eric/.openclaw/share-cep-agent/octobercms/project/index.php /home/eric/.openclaw/share-cep-agent/octobercms/project/public/index.php; fi",
      "creates": ["project/public/index.php"],
      "depends_on": ["step_fix_mirror"]
    },
    {
      "id": "step_fix_htaccess",
      "action": "create_public_htaccess",
      "working_dir": "/home/eric/.openclaw/share-cep-agent/octobercms",
      "command": "if [ -L /home/eric/.openclaw/share-cep-agent/octobercms/project/public/.htaccess ]; then rm /home/eric/.openclaw/share-cep-agent/octobercms/project/public/.htaccess && cp /home/eric/.openclaw/share-cep-agent/octobercms/project/.htaccess /home/eric/.openclaw/share-cep-agent/octobercms/project/public/.htaccess; fi",
      "creates": ["project/public/.htaccess"],
      "depends_on": ["step_fix_public_index"]
    },
    {
      "id": "step_restart_web",
      "action": "restart_web_service",
      "working_dir": "/home/eric/.openclaw/share-cep-agent/octobercms",
      "command": "docker-compose restart web",
      "creates": [],
      "depends_on": ["step_fix_htaccess"]
    },
    {
      "id": "step_final_verify",
      "action": "final_verification",
      "working_dir": "/home/eric/.openclaw/share-cep-agent/octobercms",
      "command": "sleep 3 && curl -f http://localhost:8080 && echo 'October CMS deployment successful!' || (echo 'Verification failed, checking logs...' && docker-compose logs web --tail=10)",
      "creates": [],
      "depends_on": ["step_restart_web"]
    }
  ]
}